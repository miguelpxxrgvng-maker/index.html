<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zona94_ Tienda Final</title>
<link rel="stylesheet" href="style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://www.paypal.com/sdk/js?client-id=sb&currency=EUR"></script>
</head>
<body>
<header>
<h1>Zona94_ Tienda Final</h1>
<nav>
<a href="#productos-section">Productos</a>
<a href="#carrito-section">Carrito</a>
<a href="#usuarios-section">Usuarios</a>
<a href="#admin-panel">Admin</a>
<a href="#comentarios-section">Comentarios</a>
</nav>
</header>

<main>
<h2 id="productos-section">Productos</h2>
<input type="text" id="buscador" placeholder="Buscar producto...">
<div id="productos"></div>

<h2 id="carrito-section">Carrito</h2>
<div id="carrito-productos"></div>
<p>Total: €<span id="total-final">0</span></p>
<div id="paypal-button-container"></div>

<h2 id="usuarios-section">Registro / Login</h2>
<div id="registro-login">
<input type="text" id="reg-nombre" placeholder="Nombre">
<input type="email" id="reg-email" placeholder="Email">
<input type="password" id="reg-password" placeholder="Contraseña">
<button id="btn-registrar">Registrar</button>
<br><br>
<input type="email" id="login-email" placeholder="Email">
<input type="password" id="login-password" placeholder="Contraseña">
<button id="btn-login">Login</button>
<button id="btn-logout">Logout</button>
<p id="usuario-nombre"></p>
</div>

<div id="admin-panel">
<h3>Panel Administrador</h3>
<p>Añadir producto:</p>
<input type="text" id="admin-nombre" placeholder="Nombre">
<input type="text" id="admin-categoria" placeholder="Categoría">
<input type="number" id="admin-precio" placeholder="Precio">
<input type="number" id="admin-stock" placeholder="Stock">
<input type="text" id="admin-talla" placeholder="Talla">
<input type="text" id="admin-marca" placeholder="Marca">
<input type="text" id="admin-img" placeholder="URL Imagen">
<button id="btn-agregar-producto">Agregar</button>

<h3>Editar / Eliminar productos:</h3>
<div id="lista-productos-admin"></div>

<h3>Pedidos:</h3>
<div id="lista-pedidos"></div>
</div>

<h2 id="comentarios-section">Comentarios de clientes</h2>
<div id="lista-comentarios"></div>
<div id="nuevo-comentario" style="display:none;">
<textarea id="texto-comentario" placeholder="Escribe tu opinión..."></textarea>
<input type="text" id="url-foto" placeholder="URL de tu foto (opcional)">
<button id="btn-comentar">Publicar comentario</button>
</div>

</main>

<footer>
<p>&copy; 2026 Zona94_ Todos los derechos reservados</p>
</footer>

<script>
let productos = {{ productos_data|tojson }};
let carrito = [];
let usuarioActivo = null;
let es_admin = false;

function mostrarProductos(){
    $("#productos").html("");
    productos.forEach(p=>{
        $("#productos").append(`<div class="producto">
<img src="${p.img}" alt="${p.nombre}">
<h3>${p.nombre}</h3>
<p>Marca: ${p.marca}</p>
<p>Talla: ${p.talla}</p>
<p>Precio: €${p.precio}</p>
<button onclick="agregarAlCarrito(${p.id})">Agregar al carrito</button>
</div>`);
    });
    mostrarProductosAdmin();
}

function agregarAlCarrito(id){
    let p = productos.find(x=>x.id===id);
    carrito.push(p);
    actualizarTotal();
}

function actualizarTotal(){
    let total = carrito.reduce((s,p)=>s+p.precio,0);
    $("#total-final").text(total.toFixed(2));
}

// ===== Registro / Login =====
$("#btn-registrar").click(()=>{
    $.post("/api/registrar",{nombre:$("#reg-nombre").val(),email:$("#reg-email").val(),password:$("#reg-password").val()},data=>alert(data.msg));
});

$("#btn-login").click(()=>{
    $.post("/api/login",{email:$("#login-email").val(),password:$("#login-password").val()},data=>{
        if(data.success){
            usuarioActivo = data.usuario;
            es_admin = data.usuario.es_admin;
            $("#usuario-nombre").text("Bienvenido "+usuarioActivo.nombre);
            if(es_admin) $("#admin-panel").show();
        } else alert(data.msg);
    });
});

$("#btn-logout").click(()=>{
    usuarioActivo = null;
    es_admin = false;
    $("#usuario-nombre").text("");
    $("#admin-panel").hide();
});

// ===== ADMIN =====
$("#btn-agregar-producto").click(()=>{
    let newP = {
        nombre: $("#admin-nombre").val(),
        categoria: $("#admin-categoria").val(),
        precio: parseFloat($("#admin-precio").val()),
        stock: parseInt($("#admin-stock").val()),
        talla: $("#admin-talla").val(),
        marca: $("#admin-marca").val(),
        img: $("#admin-img").val()
    };
    $.post("/api/productos", newP, data=>{
        alert(data.msg);
        productos.push(data.producto);
        mostrarProductos();
    });
});

function mostrarProductosAdmin(){
    if(!es_admin) return;
    $("#lista-productos-admin").html("");
    productos.forEach(p=>{
        $("#lista-productos-admin").append(`
<div>
${p.nombre} - €${p.precio} 
<button onclick="editarProducto(${p.id})">Editar</button>
<button onclick="eliminarProducto(${p.id})">Eliminar</button>
</div>
`);
    });
}

function editarProducto(id){
    let p = productos.find(x=>x.id===id);
    let nuevoNombre = prompt("Nombre",p.nombre);
    let nuevoPrecio = prompt("Precio",p.precio);
    if(nuevoNombre && nuevoPrecio){
        $.post("/api/producto/editar",{id:id,nombre:nuevoNombre,precio:parseFloat(nuevoPrecio)},data=>{
            alert(data.msg);
            p.nombre=nuevoNombre; p.precio=parseFloat(nuevoPrecio);
            mostrarProductos();
        });
    }
}

function eliminarProducto(id){
    if(confirm("Eliminar producto?")){
        $.post("/api/producto/eliminar",{id:id},data=>{
            alert(data.msg);
            productos = productos.filter(p=>p.id!==id);
            mostrarProductos();
        });
    }
}

// ===== PAYPAL =====
paypal.Buttons({
    createOrder:(data,actions)=>actions.order.create({purchase_units:[{amount:{value:$("#total-final").text()}}]}),
    onApprove:(data,actions)=>actions.order.capture().then(details=>{
        alert("Pago completado por "+details.payer.name.given_name);
        if(usuarioActivo){
            $.post("/api/pedido",{usuario_id:usuarioActivo.id,productos:JSON.stringify(carrito),total:$("#total-final").text()},()=>{ carrito=[]; actualizarTotal(); });
        }
    })
}).render('#paypal-button-container');

mostrarProductos();
</script>

</body>
</html>
