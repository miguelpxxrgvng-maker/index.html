# ===== API =====
@app.route("/api/registrar", methods=["POST"])
def api_registrar():
    data = request.form
    if Usuario.query.filter_by(email=data['email']).first():
        return jsonify({"msg":"Email ya registrado"})
    u = Usuario(nombre=data['nombre'], email=data['email'], password=data['password'])
    db.session.add(u); db.session.commit()
    return jsonify({"msg":"Registro exitoso"})

@app.route("/api/login", methods=["POST"])
def api_login():
    data = request.form
    u = Usuario.query.filter_by(email=data['email'], password=data['password']).first()
    if u:
        return jsonify({"success":True,"usuario":{"id":u.id,"nombre":u.nombre,"es_admin":u.es_admin}})
    return jsonify({"success":False,"msg":"Email o contraseña incorrectos"})

@app.route("/api/productos", methods=["POST"])
def api_productos():
    data = request.form
    p = Producto(nombre=data['nombre'], categoria=data['categoria'], precio=float(data['precio']),
                 stock=int(data['stock']), talla=data['talla'], marca=data['marca'], img=data['img'])
    db.session.add(p); db.session.commit()
    return jsonify({"msg":"Producto agregado","producto":{"id":p.id,"nombre":p.nombre,"categoria":p.categoria,"precio":p.precio,"stock":p.stock,"talla":p.talla,"marca":p.marca,"img":p.img}})

@app.route("/api/producto/editar", methods=["POST"])
def api_producto_editar():
    data = request.form
    p = Producto.query.get(int(data['id']))
    if not p: return jsonify({"msg":"Producto no encontrado"})
    p.nombre = data.get('nombre', p.nombre)
    p.precio = float(data.get('precio', p.precio))
    db.session.commit()
    return jsonify({"msg":"Producto editado"})

@app.route("/api/producto/eliminar", methods=["POST"])
def api_producto_eliminar():
    data = request.form
    p = Producto.query.get(int(data['id']))
    if not p: return jsonify({"msg":"Producto no encontrado"})
    db.session.delete(p); db.session.commit()
    return jsonify({"msg":"Producto eliminado"})

@app.route("/api/pedido", methods=["POST"])
def api_pedido():
    data = request.form
    pedido = Pedido(usuario_id=int(data['usuario_id']), productos=data['productos'], total=float(data['total']))
    db.session.add(pedido); db.session.commit()
    return jsonify({"msg":"Pedido registrado"})

